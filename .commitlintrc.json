{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "scope-enum": [
      2,
      "always",
      ["auth", "todos", "frontend", "backend", "config", "test", "dx"]
    ],
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "chore", "refactor", "test", "docs", "style", "ci", "perf", "revert"]
    ],
    "subject-case": [2, "always", "lower-case"],
    "header-max-length": [2, "always", 100]
  }
}
